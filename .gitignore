*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Data — raw scraped HTML/JSON is reproducible, don't commit
data/raw/
data/interim/
data/external/*.tmp
!data/raw/.gitkeep
!data/interim/.gitkeep

# DuckDB file — too large, live in release assets
data/*.duckdb
data/*.duckdb.wal

# Processed parquet — commit only if small; otherwise rely on release assets
data/processed/**/*.parquet

# Optuna study
experiments/optuna.db
experiments/optuna.db-*

# Logs
*.log
runs/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Secrets
.env
.env.*
!.env.example

# MLflow
mlruns/
